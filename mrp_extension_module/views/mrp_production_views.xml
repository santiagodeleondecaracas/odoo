<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_form_inherit_backdate" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.backdate</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <!-- Insertamos el campo después de la fecha planificada -->
              <xpath expr="//group[@name='group_extra_info']//field[@name='date_finished']" position="attributes">
            <attribute name="readonly">False</attribute>
        </xpath>
            <xpath expr="//group[@name='group_extra_info']//field[@name='date_finished']" position="after">
                <field name="forced_back_date"/>
            </xpath>
            <xpath expr="//group[@name='group_extra_info']//field[@name='date_start']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>

        </field>
    </record>
</odoo>