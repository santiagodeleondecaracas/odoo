<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PIVOT VIEW -->
    <record id="view_order_product_pivot_custom_ext" model="ir.ui.view">
        <field name="name">view.order.product.pivot.custom.ext</field>
        <field name="model">purchase.report</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price_total']" position="after">
                <field name="price_subtotal_rate" type="measure"/>
            </xpath>
        </field>
    </record>

    <!-- GRAPH VIEW -->
    <record id="view_order_product_graph_custom_ext" model="ir.ui.view">
        <field name="name">view.order.product.graph.custom.ext</field>
        <field name="model">purchase.report</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_graph"/>
        <field name="arch" type="xml">
            <xpath expr="//graph" position="inside">
                <field name="price_subtotal_rate" type="measure"/>
            </xpath>
        </field>
    </record>

    <!-- TREE/LIST VIEW FOR PURCHASE REPORT ANALYSIS -->
    <record id="purchase_report_view_tree_custom_ext" model="ir.ui.view">
        <field name="name">purchase.report.view.tree.custom.ext</field>
        <field name="model">purchase.report</field>
        <field name="inherit_id" ref="purchase.purchase_report_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price_total']" position="after">
                <field name="currency_id2" column_invisible="1"/>
                <field name="price_subtotal_rate"
                    sum="Total Moneda secundaria"
                    widget="monetary"
                    options="{'currency_field': 'currency_id2'}"/>
            </xpath>
        </field>
    </record>

</odoo>